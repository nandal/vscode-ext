{
  "name": "markdown-reader",
  "displayName": "MarkDown Reader",
  "description": "A VS Code extension to view Markdown files in a beautiful readable mode with a key combination toggle.",
  "publisher": "littlevoiceclub",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:markdownReader.toggleView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownReader.toggleView",
        "title": "Toggle Markdown Reader View"
      }
    ],
    "keybindings": [
      {
        "command": "markdownReader.toggleView",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "editorTextFocus && resourceExtname == .md"
      }
    ],
    "customEditors": [
      {
        "viewType": "markdownReader.editor",
        "displayName": "Markdown Reader",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "marked": "^9.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nandal/markdown-reader"
  },
  "license": "MIT"
}
